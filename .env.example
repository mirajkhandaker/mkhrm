# -- Database ------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=shrm
DB_USER=postgres
DB_PASS=your_password_here
DB_LOGGING=true

# -- API -----------------------------------------------------------------------
API_PORT=6000
NODE_ENV=development

# -- Auth (JWT) ----------------------------------------------------------------
